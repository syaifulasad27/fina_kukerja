#!/usr/bin/env bash
set -euo pipefail
BASE="/root/.openclaw/workspace/fina_kukerja"

if [[ $# -lt 1 ]]; then
  echo "Usage: fina-reject <approvalId> [reason] [approver]"
  echo "Example: fina-reject 123e4567-e89b-12d3-a456-426614174000 \"invalid change\" syaiful_asad"
  exit 1
fi

APPROVAL_ID="$1"
REASON="${2:-manual reject}"
APPROVER="${3:-syaiful_asad}"

cd "$BASE"
node scripts/apply_change.js --approval-id "$APPROVAL_ID" --approver "$APPROVER" --reject --reason "$REASON"
